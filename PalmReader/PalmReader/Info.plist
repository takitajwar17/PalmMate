<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Palmistry</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string></string>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>Palmistry needs your camera so you can photograph the palm to be read.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Palmistry needs photo library access so you can choose a palm photo to be read.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Palmistry can save your shareable palm reading card to your photos.</string>
	<key>OPENAI_API_KEY</key>
	<string>$(OPENAI_API_KEY)</string>
	<key>BACKEND_BASE_URL</key>
	<string>$(BACKEND_BASE_URL)</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>UIAppFonts</key>
	<array>
		<string>Fonts/CormorantGaramond-Light.ttf</string>
		<string>Fonts/CormorantGaramond-Medium.ttf</string>
		<string>Fonts/CormorantGaramond-MediumItalic.ttf</string>
		<string>Fonts/EBGaramond-Regular.ttf</string>
		<string>Fonts/EBGaramond-Italic.ttf</string>
		<string>Fonts/JetBrainsMono-Regular.ttf</string>
		<string>Fonts/JetBrainsMono-Medium.ttf</string>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.palmistry.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>palmistry</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
